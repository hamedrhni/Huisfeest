# ---------------------------------------------------------------------------
# HuisFeest — environment variables
# Copy this file to `.env.local` and fill in real values for local development.
# In Coolify, set these in the application's Environment Variables panel.
# ---------------------------------------------------------------------------

# Public base URL of the site. Used for absolute URLs, SEO metadata, og tags.
# Set to https://huisfeest.nl when the domain is live in Coolify.
NEXT_PUBLIC_BASE_URL=https://huisfeest.nl

# Business WhatsApp number in international format, DIGITS ONLY (no +, spaces).
# Placeholder: +31 6 00000000 → 31600000000. REPLACE BEFORE LAUNCH.
NEXT_PUBLIC_WHATSAPP_NUMBER=31600000000

# Public contact email shown on the site and in email footers.
# TODO: replace with real inbox before launch.
NEXT_PUBLIC_CONTACT_EMAIL=hallo@huisfeest.nl

# ---------------------------------------------------------------------------
# Admin dashboard
# ---------------------------------------------------------------------------

# Shared admin login password (single user, V1). Use a long random value.
ADMIN_PASSWORD=change-me-in-production

# Secret used to sign the admin session cookie (HMAC).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=please-generate-a-long-random-secret

# ---------------------------------------------------------------------------
# Lead storage — PostgreSQL (Coolify)
# ---------------------------------------------------------------------------
# Leave DATABASE_URL unset for local dev to use the JSON file stub.
# In Coolify: add a PostgreSQL service and paste its connection string here.
#
# Coolify auto-generates this when you link a PostgreSQL service:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
#
# After first deploy, run migrations:
#   npx prisma db push
# Or if using migrations:
#   npx prisma migrate deploy
# DATABASE_URL=

# Force the storage backend explicitly (optional — DATABASE_URL auto-activates postgres):
# LEAD_STORE=postgres   ← uses PostgreSQL
# LEAD_STORE=json       ← forces JSON stub (local dev default)

# ---------------------------------------------------------------------------
# Transactional email — Resend
# ---------------------------------------------------------------------------
# Leave RESEND_API_KEY unset to skip email sending (safe — no crash).
# Get your API key at https://resend.com
# RESEND_API_KEY=re_...

# Admin inbox for new inquiry notifications. Defaults to NEXT_PUBLIC_CONTACT_EMAIL.
# ADMIN_EMAIL=hallo@huisfeest.nl

# Resend "from" address — must be on a domain verified in your Resend account.
# TODO: verify huisfeest.nl in Resend, then set this to the verified address.
# EMAIL_FROM=HuisFeest <noreply@huisfeest.nl>

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# Show the testimonials section. Set to true ONLY when real reviews are in content/.
SHOW_TESTIMONIALS=false

# Soft-launch / maintenance mode.
# When true: all public routes show a branded "coming soon" page. /admin still works.
# Requires a redeploy to take effect (value baked at build time for SSG pages).
MAINTENANCE_MODE=false
